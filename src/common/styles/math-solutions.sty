\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{math-solutions}

% 预配置
% 防止 fontspec 干扰数学字体（在使用 XeLaTeX 时建议启用）
\PassOptionsToPackage{no-math}{fontspec}
\PassOptionsToPackage{partial=upright}{unicode-math}

% 基础与工具宏包
\RequirePackage{import}              % 支持相对路径导入文件
\RequirePackage[
    dvipsnames,
    svgnames
]{xcolor}                            % 颜色支持
% \RequirePackage{emptypage}           % 自动清除偶数空白页的页眉页脚（优雅替代手工 hack）

% 页面布局与几何设置
\RequirePackage[
    inner=1.5cm,
    outer=1.5cm,
    top=2cm,
    bottom=1.5cm,
    marginparwidth=2cm,
    marginparsep=0.4cm,
    includefoot,
    heightrounded
]{geometry}
% \raggedbottom                      % 允许页面底部不对齐，避免过度拉伸垂直间距

% 数学与物理核心宏包
\RequirePackage{amsmath}             % AMS 数学核心
\RequirePackage{amsthm}              % AMS 定理环境
\RequirePackage{amssymb}             % AMS 数学符号

\RequirePackage{unicode-math}        % Unicode 数学字体支持
% 设置数学字体为 Latin Modern Math
% \setmathfont{latinmodern-math.otf}
% 设置数学字体为 New Computer Modern Math（更现代的设计）
\setmathfont{NewCMMath-Book.otf}
% 设置数学字体为 STIX Two Math（科学出版物常用的字体，清晰且专业）
% \setmathfont{STIXTwoMath-Regular.otf}
% \setmathfont{texgyretermes-math.otf}

% 常用正体符号定义
\newcommand{\e}{\symup{e}}          % 自然对数底
\newcommand{\uppi}{\symup{\pi}}      % 圆周率
\newcommand{\ii}{\symup{i}}          % 虚数单位

% 符号扩展
\RequirePackage{fixdif}              % 完美的微分算子格式修正
\RequirePackage{emoji}

% 图形与表格
\RequirePackage{graphicx}            % 图片插入
\RequirePackage{float}               % 浮动体控制（H 选项）
\RequirePackage{caption}             % 图表标题定制

\RequirePackage{tikz}                % 绘图工具
\usetikzlibrary{arrows.meta, angles, quotes, calc, patterns}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}

\RequirePackage{tabularray}          % 现代表格宏包
\RequirePackage{booktabs}            % 三线表
\RequirePackage{multirow}            % 跨行单元格
\RequirePackage{scalerel}            % 符号缩放
\RequirePackage{enumitem}

% 多栏与彩色盒子
\RequirePackage{multicol}            % 多栏环境
\RequirePackage{tcolorbox}           % 彩色文本框
\tcbuselibrary{skins, breakable, theorems}

% 参考文献管理
\RequirePackage[
    backend=biber,
    style=gb7714-2015,
    sorting=none,
    backref=true
]{biblatex}

% 交叉引用与超链接（严格加载顺序：hyperref -> bookmark -> cleveref）
\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=red,
    citecolor=red,
    urlcolor=red,
    bookmarksnumbered=true,
    pdfstartview=FitH
}
\RequirePackage{bookmark}            % 书签增强

\RequirePackage{cleveref}            % 智能交叉引用
\crefname{equation}{公式}{公式}
\Crefname{equation}{公式}{公式}


% 解析环境配置
\allowdisplaybreaks[2] % 允许在多行公式中断页，级别 2 是适度允许

\setlist[enumerate,1]{
    label=(\arabic*),
    leftmargin=2.6em,
    itemsep=0.25ex,
    topsep=0.5ex,
    parsep=0pt,
    partopsep=0pt
}

\NewDocumentEnvironment{solution}{}%
{\par\smallskip\noindent\textbf{解}\par\noindent\ignorespaces}%
{\par\noindent\hfill$\blacksquare$\par\smallskip}

\NewDocumentEnvironment{myproof}{}%
{\par\smallskip\noindent\textbf{证明}\par\noindent\ignorespaces}%
{\par\noindent\hfill$\square$\par\smallskip}

% 解答中按子问给出答案
\newcommand{\ansitem}[1]{%
    \par\smallskip\noindent{(#1)}\quad\ignorespaces
}

% tcb配置
\newtcbtheorem[number within=section]{problem}{习题}{
    enhanced,
    breakable,
    colback=gray!2,
    colframe=gray!60,
    colbacktitle=gray!15,  % 标题背景颜色
    coltitle=black,
    fonttitle=\heiti,      % 使用中文字体黑体
    boxrule=0.6pt,
    titlerule=0.4pt,       % 标题与内容间的分割线
    arc=2mm,
    top=1em,
    separator sign none,
    description font=\normalfont\kaishu, % 备注使用楷体
    after title={\hspace{0.5em}---},     % 标题后的横杠
    segmentation style={dash pattern=on 3pt off 2pt, gray!40}, % 如果有分割线用虚线
}{prob}

\newtcbtheorem[number within=section]{note}{注释}{
    enhanced,
    breakable,
    colback=orange!2,
    colframe=orange!60,
    colbacktitle=orange!15,  % 标题背景颜色
    coltitle=black,
    fonttitle=\heiti,      % 使用中文字体黑体
    boxrule=0.6pt,
    titlerule=0.4pt,       % 标题与内容间的分割线
    arc=2mm,
    top=1em,
    separator sign none,
    description font=\normalfont\kaishu, % 备注使用楷体
    after title={\hspace{0.5em}---},     % 标题后的横杠
    segmentation style={dash pattern=on 3pt off 2pt, orange!40}, % 如果有分割线用虚线
}{note}

% 页眉页脚设定 (fancyhdr)
\RequirePackage{fancyhdr}
\addtolength{\headheight}{1.6pt}
\pagestyle{fancy}
\fancyhf{} % 清空默认的页眉页脚

\fancyhead[LE]{\bfseries\thepage}
\fancyhead[RE]{\bfseries\leftmark}
\fancyhead[LO]{\bfseries\rightmark}
\fancyhead[RO]{\bfseries\thepage}

\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}

\renewcommand{\chaptermark}[1]{\markboth{\if@mainmatter\CTEXthechapter\fi\quad #1}{}}
\renewcommand{\sectionmark}[1]{\markright{\S\thesection\quad #1}}

% 目录排版优化
\renewcommand\tableofcontents{%
    \chapter*{\contentsname}%
    \@mkboth{\MakeUppercase\contentsname}{\MakeUppercase\contentsname}%
    \begin{multicols}{2}
        \@starttoc{toc}%
    \end{multicols}
}


